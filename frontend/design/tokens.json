{
  "$meta": {
    "name": "Rabbit Hole — Spotify-inspired token set",
    "provenance": "Observation-derived (clean-room). See DESIGN-NOTES.md. NOT extracted from Spotify asset/code files.",
    "note": "A concept design system inspired by Spotify's public visual language. No Spotify assets, fonts, or code are used."
  },
  "color": {
    "brand": {
      "green": "#1DB954",
      "greenBright": "#1ED760",
      "greenPressed": "#1AA34A"
    },
    "surface": {
      "base": "#121212",
      "raised": "#181818",
      "raisedHover": "#1F1F1F",
      "overlay": "#282828",
      "overlayHover": "#3E3E3E"
    },
    "border": {
      "subtle": "#292929",
      "strong": "#3E3E3E"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#B3B3B3",
      "tertiary": "#6A6A6A",
      "onBrand": "#000000"
    },
    "state": {
      "focusRing": "#1ED760",
      "error": "#E03D3D"
    }
  },
  "font": {
    "family": {
      "sans": "Figtree, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "black": 900
    },
    "size": {
      "caption": "0.75rem",
      "bodySm": "0.875rem",
      "body": "1rem",
      "headingSm": "1.25rem",
      "heading": "1.5rem",
      "display": "2rem",
      "displayLg": "3rem"
    },
    "lineHeight": {
      "tight": 1.1,
      "snug": 1.3,
      "normal": 1.5
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.1em"
    }
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "6": "24px",
    "8": "32px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "500px"
  },
  "shadow": {
    "card": "0 4px 12px rgba(0,0,0,0.4)",
    "raised": "0 8px 24px rgba(0,0,0,0.5)"
  },
  "motion": {
    "fast": "120ms",
    "base": "200ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
